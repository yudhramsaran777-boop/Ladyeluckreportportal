# ============================================================
# Supabase (existing — do not change variable names)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# ============================================================
# App URL (used by the OAuth callback redirect)
# ============================================================
NEXT_PUBLIC_APP_URL=https://your-app-domain.vercel.app

# ============================================================
# Google OAuth (Gmail readonly access)
# Create credentials at: https://console.cloud.google.com
#   APIs & Services > Credentials > Create OAuth 2.0 Client ID
#   Application type: Web application
#   Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/gmail/callback
# ============================================================
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-app-domain.vercel.app/api/gmail/callback

# ============================================================
# Gmail OAuth state signing secret
# Prevents CSRF during the OAuth flow.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
GMAIL_OAUTH_STATE_SECRET=

# ============================================================
# AES-256-GCM encryption key for Gmail OAuth tokens
# Must be exactly 64 hex characters (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET. Rotating it invalidates all stored connections.
# ============================================================
PAYMENT_TOKEN_ENCRYPTION_KEY=

# ============================================================
# Dashboard Bearer token signing secret
# Used to sign short-lived (15-minute) tokens for the external dashboard.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
DASHBOARD_TOKEN_SECRET=

# ============================================================
# Dashboard CORS allowed origins
# Comma-separated exact origin strings (no wildcards in production).
# Example: https://my-dashboard.vercel.app,https://staging.example.com
# ============================================================
DASHBOARD_ALLOWED_ORIGINS=https://your-dashboard-origin.example.com
